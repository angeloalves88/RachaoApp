{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": false,
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@rachao/db": ["../../packages/db/src/index.ts"],
      "@rachao/shared": ["../../packages/shared/src/index.ts"],
      "@rachao/shared/zod": ["../../packages/shared/src/zod.ts"],
      "@rachao/shared/enums": ["../../packages/shared/src/enums.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
