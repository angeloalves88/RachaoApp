# Copie para apps/web/.env.local

# Porta do Next dev (lida pelo scripts/dev.mjs). Fallback: 3000.
WEB_PORT=3000

# Supabase (Kong local). Se o login der "Failed to fetch" no Windows, use 127.0.0.1 em vez de localhost.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# Backend Fastify
NEXT_PUBLIC_API_URL=http://localhost:3333

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Suporte (CTAs em /configuracoes). Numero em formato 11 digitos (DDD+9+numero)
# ou ja com 55 na frente; vazio esconde o botao do WhatsApp.
NEXT_PUBLIC_SUPORTE_WHATSAPP=
NEXT_PUBLIC_SUPORTE_EMAIL=suporte@rachao.app

# PWA: habilita o service worker / manifest (T34 / Fase 3). Use "true" para ligar.
NEXT_PUBLIC_PWA_ENABLED=false

# Script `pnpm seed:boleiros` (cadastro em massa de boleiros de teste). Não commitar senha.
# RACHAO_SEED_EMAIL=
# RACHAO_SEED_PASSWORD=
# RACHAO_GRUPO_ID=   # opcional; se vazio, usa o primeiro grupo da conta
