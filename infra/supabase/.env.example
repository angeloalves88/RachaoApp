# =============================================================================
# RachaoApp - Supabase Self-Hosted (Docker)
# =============================================================================
# Copie este arquivo para infra/supabase/.env antes de subir os containers.
# Para producao gere novas chaves em https://supabase.com/docs/guides/self-hosting/docker

############
# Postgres
############
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=rachao-dev-password-change-me
# Porta no Windows (host). Se der erro de bind, troque (ex: 55432) e alinhe o DATABASE_URL do app.
POSTGRES_HOST_PORT=15432

############
# JWT (chaves de DEV ja assinadas com o JWT_SECRET abaixo)
# IMPORTANTE: Para producao, gere novas chaves seguindo a doc do Supabase.
############
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

############
# Studio Dashboard
############
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=rachao
STUDIO_DEFAULT_ORGANIZATION=RachaoApp
STUDIO_DEFAULT_PROJECT=RachaoApp Dev

############
# Kong (API Gateway)
############
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############
# Auth (GoTrue)
############
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

############
# SMTP (deixe assim para dev - emails sao logados no console do GoTrue)
############
SMTP_ADMIN_EMAIL=admin@rachaoapp.local
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=RachaoApp
ENABLE_EMAIL_CONFIRMATIONS=false
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

############
# Google OAuth (preencha quando configurar)
############
ENABLE_GOOGLE_PROVIDER=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

############
# Storage / Imgproxy
############
IMGPROXY_ENABLE_WEBP_DETECTION=true

############
# Analytics (desabilitado em dev)
############
LOGFLARE_LOGGER_BACKEND_API_KEY=
LOGFLARE_API_KEY=

############
# URLs publicas (usadas pelo Studio)
############
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
