# =============================================================================
# RachaoApp — Producao (Docker Swarm + Traefik)
# Copie para: infra/docker/.env
#   cp .env.production.example .env
# =============================================================================

# --- Traefik (mesma rede do CoreBot / seu proxy) ---
TRAEFIK_NETWORK=PDRCOREBOT

# --- Dominios (DNS A/AAAA apontando para a VPS) ---
WEB_DOMAIN=rachaoapp.dafetech.com.br
API_DOMAIN=api.rachaoapp.dafetech.com.br
SUPABASE_DOMAIN=sb.rachaoapp.dafetech.com.br

# URLs publicas (usadas pelo app e GoTrue)
SITE_URL=https://rachaoapp.dafetech.com.br
ADDITIONAL_REDIRECT_URLS=https://rachaoapp.dafetech.com.br/**
API_EXTERNAL_URL=https://sb.rachaoapp.dafetech.com.br
SUPABASE_PUBLIC_URL=https://sb.rachaoapp.dafetech.com.br

# --- Imagens Docker (apos build local ou registry) ---
CR_IMAGE_WEB=rachao-web:latest
CR_IMAGE_API=rachao-api:latest
CR_IMAGE_MIGRATE=rachao-migrate:latest

# =============================================================================
# Postgres + JWT Supabase
# GERE NOVOS VALORES EM PRODUCAO:
# https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# =============================================================================
POSTGRES_DB=postgres
# Use aspas se a senha tiver $ # espacos. Deve ser a MESMA senha usada por auth/rest/storage.
# O init 01-sync-role-passwords.sh alinha os roles Supabase com este valor.
POSTGRES_PASSWORD="ALTERE-senha-postgres-forte"
# Host do Postgres no Swarm (padrao: rachao-supabase_db). Nao use "db" salvo se o alias funcionar.
DATABASE_HOST=rachao-supabase_db
SUPABASE_STACK_NAME=rachao-supabase
# Opcional: URL completa ja escapada (sobrescreve POSTGRES_PASSWORD + DATABASE_HOST)
# DATABASE_URL=postgresql://supabase_admin:senha%24encodada@rachao-supabase_db:5432/postgres?schema=public

JWT_SECRET=ALTERE-jwt-secret-minimo-32-caracteres
JWT_EXPIRY=3600

# Chaves assinadas com JWT_SECRET acima (nao use as de dev)
ANON_KEY=ALTERE-anon-key-jwt
SERVICE_ROLE_KEY=ALTERE-service-role-key-jwt

# Studio / Kong dashboard (basic auth no Kong)
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=ALTERE-senha-studio-forte

STUDIO_DEFAULT_ORGANIZATION=RachaoApp
STUDIO_DEFAULT_PROJECT="RachaoApp Producao"

# =============================================================================
# Auth / SMTP
# =============================================================================
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
# Sem comentario na mesma linha (true #false quebra o GoTrue)
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

SMTP_ADMIN_EMAIL=noreply@rachao.app
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=ALTERE-smtp
SMTP_SENDER_NAME=RachaoApp

ENABLE_GOOGLE_PROVIDER=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

IMGPROXY_ENABLE_WEBP_DETECTION=true
LOGFLARE_API_KEY=

# =============================================================================
# API (Fastify) — RESEND / ASAAS (opcional)
# =============================================================================
RESEND_API_KEY=
RESEND_FROM="RachaoApp <noreply@rachao.app>"
RESEND_WEBHOOK_SECRET=

ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=

ENABLE_NOTIFICATION_JOBS=true
NOTIFICATION_JOBS_INTERVAL_MIN=30

# =============================================================================
# Build da imagem web (NEXT_PUBLIC_* — embutidos no bundle)
# Preencha antes de: ./build-images.sh
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://sb.rachaoapp.dafetech.com.br
NEXT_PUBLIC_SUPABASE_ANON_KEY=MESMO_VALOR_DE_ANON_KEY
NEXT_PUBLIC_API_URL=https://api.rachaoapp.dafetech.com.br
NEXT_PUBLIC_APP_URL=https://rachaoapp.dafetech.com.br
NEXT_PUBLIC_SUPORTE_EMAIL=suporte@rachao.app
NEXT_PUBLIC_SUPORTE_WHATSAPP=
NEXT_PUBLIC_PWA_ENABLED=true
